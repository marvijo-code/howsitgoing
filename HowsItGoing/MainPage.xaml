<Page x:Class="HowsItGoing.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:contracts="using:HowsItGoing.Contracts"
      Background="#FFF7ED">
  <Page.Resources>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFBEB" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFF97316" />
    <SolidColorBrush x:Key="MutedBrush" Color="#FF78716C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFC2410C" />
  </Page.Resources>

  <Grid Padding="16" RowDefinitions="Auto,*">
    <Border Padding="18"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="24">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock FontSize="30"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AccentBrush}"
                     Text="How's It Going" />
          <TextBlock Margin="0,6,0,0"
                     Foreground="{StaticResource MutedBrush}"
                     Text="{Binding StatusBanner}" />
        </StackPanel>
        <Button Grid.Column="1"
                VerticalAlignment="Center"
                Click="RefreshButton_Click"
                Content="Refresh" />
      </Grid>
    </Border>

    <Pivot Grid.Row="1"
           Margin="0,16,0,0">
      <PivotItem Header="Sessions">
        <Grid RowDefinitions="Auto,Auto,*">
          <Border Padding="16"
                  Background="{StaticResource CardBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="20">
            <Grid ColumnDefinitions="*,Auto"
                  RowDefinitions="Auto,Auto">
              <TextBox Header="Bridge URL"
                       Text="{Binding BridgeBaseUrl, Mode=TwoWay}" />
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom">
                <CheckBox Content="Foreground monitoring"
                          IsChecked="{Binding MonitoringEnabled, Mode=TwoWay}" />
                <Button Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Click="SaveButton_Click"
                        Content="Save" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Margin="0,16,0,16"
                  Padding="16"
                  Background="{StaticResource CardBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="20">
            <StackPanel>
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}"
                         Text="Filter Codex Sessions" />
              <TextBox Margin="0,12,0,0"
                       Header="Search"
                       PlaceholderText="Prompt, repo path, branch, or agent"
                       Text="{Binding SearchQuery, Mode=TwoWay}" />
              <Grid Margin="0,12,0,0"
                    ColumnDefinitions="*,*,Auto">
                <ComboBox ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" />
                <ComboBox Grid.Column="1"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding SourceFilters}"
                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}" />
                <CheckBox Grid.Column="2"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          Content="Archived"
                          IsChecked="{Binding IncludeArchived, Mode=TwoWay}" />
              </Grid>
            </StackPanel>
          </Border>

          <ListView Grid.Row="2"
                    ItemsSource="{Binding Sessions}"
                    SelectionMode="None">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="contracts:CodexSessionSummaryDto">
                <Border Margin="0,0,0,12"
                        Padding="14"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                  <StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock FontSize="18"
                                 FontWeight="SemiBold"
                                 Text="{Binding Title}"
                                 TextWrapping="Wrap" />
                      <Border Grid.Column="1"
                              Padding="10,4"
                              Background="#FFFED7AA"
                              CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding Status}" />
                      </Border>
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               FontFamily="Consolas"
                               Foreground="{StaticResource MutedBrush}"
                               Text="{Binding WorkingDirectory}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding LastAgentMessage}"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,10,0,0"
                          ColumnDefinitions="Auto,Auto,Auto">
                      <TextBlock Foreground="{StaticResource MutedBrush}"
                                 Text="{Binding Source}" />
                      <TextBlock Grid.Column="1"
                                 Margin="16,0,0,0"
                                 Foreground="{StaticResource MutedBrush}"
                                 Text="{Binding GitBranch}" />
                      <TextBlock Grid.Column="2"
                                 Margin="16,0,0,0"
                                 Foreground="{StaticResource MutedBrush}"
                                 Text="{Binding UpdatedAt}" />
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </PivotItem>

      <PivotItem Header="Notifications">
        <Grid RowDefinitions="Auto,*">
          <Border Padding="16"
                  Background="{StaticResource CardBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="20">
            <StackPanel>
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}"
                         Text="GitHub + Release Status" />
              <TextBlock Margin="0,12,0,0"
                         Text="{Binding RepositorySummary}"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="{StaticResource MutedBrush}"
                         Text="{Binding UpdateSummary}"
                         TextWrapping="Wrap" />
              <Button Margin="0,12,0,0"
                      HorizontalAlignment="Left"
                      Click="OpenRelease_Click"
                      Content="Open Latest Release" />
            </StackPanel>
          </Border>

          <ListView Grid.Row="1"
                    Margin="0,16,0,0"
                    ItemsSource="{Binding Notifications}"
                    SelectionMode="None">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="contracts:BridgeNotificationDto">
                <Border Margin="0,0,0,12"
                        Padding="14"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                  <StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock FontSize="18"
                                 FontWeight="SemiBold"
                                 Text="{Binding Title}"
                                 TextWrapping="Wrap" />
                      <TextBlock Grid.Column="1"
                                 Foreground="{StaticResource MutedBrush}"
                                 Text="{Binding OccurredAt}" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Message}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="{Binding Kind}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </PivotItem>

      <PivotItem Header="Agent">
        <ScrollViewer>
          <StackPanel>
            <Border Padding="16"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
              <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Text="Start a Codex Thread" />
                <TextBox Margin="0,12,0,0"
                         Header="Repo Path on the Bridge Machine"
                         Text="{Binding AgentRepoPath, Mode=TwoWay}" />
                <TextBox Margin="0,12,0,0"
                         Header="Model (Optional)"
                         Text="{Binding AgentModel, Mode=TwoWay}" />
                <TextBox Margin="0,12,0,0"
                         Header="Prompt"
                         AcceptsReturn="True"
                         Height="180"
                         Text="{Binding AgentPrompt, Mode=TwoWay}"
                         TextWrapping="Wrap" />
                <Button Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Click="StartAgent_Click"
                        Content="Start Codex Thread" />
                <TextBlock Margin="0,12,0,0"
                           Text="{Binding LaunchResult}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </PivotItem>
    </Pivot>
  </Grid>
</Page>
